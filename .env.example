SOVA_SUPABASE_URL=
SOVA_SUPABASE_SERVICE_ROLE_KEY=
SOVA_ETHER_SIGNAL_SECRET=
SOVA_SIGNAL_RPC=ether_signal
SOVA_SIGNAL_TABLE=ether_signals
