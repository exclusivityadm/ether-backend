# Ether (SEALED) environment

# Required: internal-only token
ETHER_INTERNAL_TOKEN=REPLACE_ME_WITH_LONG_RANDOM

# Allowed internal callers (enforced when X-ETHER-SOURCE provided)
ETHER_ALLOWED_SOURCES=exclusivity,sova,circa_haus,admin

# CORS (recommended: none)
# Options: none | allowlist
ETHER_CORS_MODE=none
ETHER_CORS_ALLOW_ORIGINS=

# Safety
ETHER_MAX_BODY_BYTES=1048576
ETHER_INGEST_RPM=120
ETHER_REPLAY_TTL_SECONDS=600

# Control-plane foundation
ETHER_ENVIRONMENT=development
ETHER_ADMIN_AUDIT_LOG=true
ETHER_BOOTSTRAP_EXPOSE_PUBLIC_CONFIG=false

# Optional override: JSON array of project records.
# Leave blank to use the built-in default registry containing Circa Haus, Exclusivity, and Sova.
ETHER_PROJECT_REGISTRY_JSON=

# Backward-compatible alias for older Ether project modules.
# You usually do not need both. If both are set, the code treats them as equivalent sources.
ETHER_PROJECTS_JSON=

# Optional: version fingerprint
ETHER_VERSION=2.1.0-foundation
GIT_SHA=
